{
  "name": "bd-geodata",
  "version": "1.0.0",
  "description": "Open-source geographic data for Bangladesh — divisions, districts, upazilas, postcodes, and full boundary GeoJSON.",
  "keywords": [
    "bangladesh",
    "geojson",
    "geo",
    "divisions",
    "districts",
    "upazilas",
    "postcodes",
    "bn",
    "bangla",
    "map"
  ],
  "author": "Fahim Reza <https://github.com/ifahimreza>",
  "license": "MIT",
  "homepage": "https://geojson.bd",
  "repository": {
    "type": "git",
    "url": "https://github.com/Y3454R/bd-geodata.git"
  },
  "bugs": {
    "url": "https://github.com/Y3454R/bd-geodata/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./boundary": "./src/data/bangladesh.geojson",
    "./bazars": "./src/data/bd-bazars.geojson",
    "./routes": "./src/data/bd-major-routes.geojson",
    "./divisions": "./src/data/bd-divisions.json",
    "./districts": "./src/data/bd-districts.json",
    "./upazilas": "./src/data/bd-upazilas.json",
    "./postcodes": "./src/data/bd-postcodes.json",
    "./dhaka-city": "./src/data/dhaka-city.json"
  },
  "files": [
    "dist",
    "src/data",
    "src/types.ts",
    "src/index.ts",
    "README.md",
    "LICENSE",
    "LICENSE-DATA"
  ],
  "scripts": {
    "validate": "node scripts/validate-data.js",
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist",
    "demo:dev": "npm --prefix demo run dev",
    "demo:build": "npm --prefix demo run build",
    "demo:install": "npm --prefix demo install"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.4.0"
  }
}
